{
  "name": "@razroo/iso-harness",
  "version": "0.1.3",
  "description": "One config for every coding agent — Cursor, Claude Code, Codex, OpenCode.",
  "type": "module",
  "bin": {
    "iso-harness": "./bin/iso-harness.mjs"
  },
  "scripts": {
    "build:example": "node ./bin/iso-harness.mjs build --source examples/minimal/iso --out examples/minimal/out",
    "smoke": "node ./bin/iso-harness.mjs build --source examples/minimal/iso --out /tmp/iso-harness-smoke",
    "release:check-source": "node ./scripts/release/check-source.mjs",
    "prepublishOnly": "npm run smoke"
  },
  "files": [
    "bin",
    "src",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "claude-code",
    "cursor",
    "codex",
    "opencode",
    "agents",
    "mcp",
    "config",
    "transpiler"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/razroo/iso-harness.git"
  },
  "bugs": {
    "url": "https://github.com/razroo/iso-harness/issues"
  },
  "homepage": "https://github.com/razroo/iso-harness#readme",
  "author": "Razroo",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "yaml": "^2.6.0"
  }
}
